# Database
LIBERADO_DATABASE_URL=postgresql://liberado:liberado@localhost:5432/liberado
LIBERADO_DB_MAX_CONNECTIONS=5

# Transport: "stdio" or "http"
LIBERADO_TRANSPORT=stdio
LIBERADO_HTTP_HOST=0.0.0.0
LIBERADO_HTTP_PORT=8080

# Auth (stdio mode: identifies the default user for this session)
LIBERADO_DEFAULT_API_KEY=

# External APIs
LIBERADO_USDA_API_KEY=

# Advisor LLM estimator: "none", "claude", or "ollama"
LIBERADO_ESTIMATOR_PROVIDER=none
LIBERADO_ESTIMATOR_MODEL=claude-opus-4-7
LIBERADO_ESTIMATOR_API_KEY=
LIBERADO_ESTIMATOR_BASE_URL=http://localhost:11434   # used for ollama

# Food search tuning
LIBERADO_SEARCH_STRONG_MATCH_THRESHOLD=0.6
LIBERADO_SEARCH_MAX_WEAK_RESULTS=3
